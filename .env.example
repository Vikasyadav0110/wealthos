# Server-side API keys (optional). If set, the app works without each user
# entering their own key in Settings. A key sent from the browser always wins.
# .env* is gitignored — copy this to .env.local and fill in real values.

# Anthropic (Claude) API key — https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# NewsAPI.org key — https://newsapi.org
NEWSAPI_KEY=
